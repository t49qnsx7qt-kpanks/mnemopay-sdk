# Normalize line endings — stop the LF/CRLF churn that turns every Windows
# commit into noise. Without this, `git add` rewrites every text file because
# the working tree has CRLF but the index expects LF.
* text=auto eol=lf

# Force LF for source and config — even if a Windows editor saved them as CRLF,
# the index keeps LF so diffs stay clean across machines.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf

# Windows-only artifacts keep CRLF (PowerShell, batch).
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.mp4       binary
*.mov       binary
*.webm      binary
*.mp3       binary
*.wav       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.7z        binary
*.exe       binary
*.dll       binary
*.so        binary
*.wasm      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.sqlite    binary
*.sqlite3   binary
*.db        binary
