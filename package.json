{
  "name": "@mnemopay/sdk",
  "version": "1.2.0",
  "description": "Production payment infrastructure for AI agents — real Stripe/Paystack/Lightning rails, autonomous shopping with escrow, Agent Credit Score (300-850), Ed25519 identity, behavioral finance, Merkle integrity, anomaly detection, human-in-the-loop approval. Battle-tested.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware/openai": {
      "import": "./dist/middleware/openai.js",
      "types": "./dist/middleware/openai.d.ts"
    },
    "./middleware/anthropic": {
      "import": "./dist/middleware/anthropic.js",
      "types": "./dist/middleware/anthropic.d.ts"
    },
    "./langgraph": {
      "import": "./dist/langgraph/tools.js",
      "types": "./dist/langgraph/tools.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    },
    "./recall": {
      "import": "./dist/recall/engine.js",
      "types": "./dist/recall/engine.d.ts"
    },
    "./rails": {
      "import": "./dist/rails/index.js",
      "types": "./dist/rails/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/sqlite.js",
      "types": "./dist/storage/sqlite.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./commerce": {
      "import": "./dist/commerce.js",
      "types": "./dist/commerce.d.ts"
    },
    "./commerce/checkout": {
      "import": "./dist/commerce/checkout/index.js",
      "types": "./dist/commerce/checkout/index.d.ts"
    },
    "./commerce/providers": {
      "import": "./dist/commerce/providers/index.js",
      "types": "./dist/commerce/providers/index.d.ts"
    }
  },
  "bin": {
    "mnemopay-mcp": "dist/mcp/server.js",
    "mnemopay-setup": "dist/cli/setup.js",
    "mnemopay-dashboard": "dist/cli/dashboard.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "agent-payments",
    "agent-memory",
    "agent-banking",
    "agent-identity",
    "agent-wallet",
    "ai-wallet",
    "llm-payments",
    "agentic-commerce",
    "mcp-payments",
    "payment",
    "escrow",
    "double-entry-ledger",
    "fraud-detection",
    "multi-agent",
    "mcp",
    "model-context-protocol",
    "paystack",
    "stripe",
    "lightning",
    "cognitive-memory",
    "kya",
    "know-your-agent",
    "reputation",
    "agent-sdk",
    "ai-memory",
    "micropayments",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "langchain",
    "langgraph",
    "agent-credit-score",
    "fintech",
    "agent-escrow",
    "shopify",
    "autonomous-shopping",
    "browser-checkout",
    "ed25519",
    "hitl",
    "human-in-the-loop",
    "agent-fico",
    "credit-score",
    "firecrawl"
  ],
  "author": "Jerry Omiagbo <jeremiah@getbizsuite.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemopay/mnemopay-sdk.git"
  },
  "homepage": "https://github.com/mnemopay/mnemopay-sdk",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "@langchain/core": ">=0.2.0",
    "@langchain/langgraph": ">=0.1.0",
    "@langchain/openai": ">=0.1.0",
    "openai": ">=4.0.0",
    "zod": ">=3.22.0",
    "stripe": ">=14.0.0",
    "better-sqlite3": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "stripe": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^4.17.21",
    "express": "^4.21.0"
  }
}
